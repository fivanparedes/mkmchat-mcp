# Copy to .env.docker and adjust values for your machine

# Python API container runtime variables
OLLAMA_BASE_URL=http://ollama:11434
MKM_HTTP_HOST=0.0.0.0

# Laravel container runtime variables (used by docker-compose interpolation)
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
DB_CONNECTION=sqlite
MKM_API_URL=http://python-api:8080
MKM_DAILY_LIMIT=0
# Optional: set a fixed key; if empty, container generates one on first boot
APP_KEY=
