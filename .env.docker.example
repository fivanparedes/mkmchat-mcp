# Copy to .env.docker and adjust values for your machine

# Python API container runtime variables
OLLAMA_BASE_URL=http://ollama:11434
MKM_HTTP_HOST=0.0.0.0
OLLAMA_MODEL=llama3.2:3b
MKM_API_KEY=change-me-in-production
MKM_API_KEY_HEADER=X-API-Key
MKM_CORS_ORIGINS=http://localhost:8000
MKM_MAX_REQUEST_SIZE=1048576
MKM_MAX_STRATEGY_LENGTH=2000
MKM_MAX_QUESTION_LENGTH=2000
# Optional override specifically for /explain-mechanic request length
# MKM_MAX_MECHANIC_LENGTH=2000
MKM_RATE_LIMIT_ENABLED=true
MKM_RATE_LIMIT_PER_MINUTE=20
MKM_RATE_LIMIT_BURST=5
MKM_RATE_LIMIT_BURST_WINDOW_SECONDS=10
MKM_HTTP_TIMEOUT_SECONDS=7200

# Explain-mechanic prompt/generation tuning (new)
MKM_MECHANIC_RAG_TOP_K=16
MKM_MECHANIC_RAG_MAX_PASSAGES=8
MKM_MECHANIC_RAG_MAX_CHARS=2400
MKM_MECHANIC_NUM_PREDICT=1200

# Ollama runtime tuning for constrained machines
OLLAMA_KEEP_ALIVE=15m
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1

# Laravel container runtime variables (used by docker-compose interpolation)
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
DB_CONNECTION=sqlite
MKM_API_URL=http://python-api:8080
MKM_API_KEY=change-me-in-production
MKM_API_KEY_HEADER=X-API-Key
MKM_WEB_RATE_LIMIT_PER_MINUTE=10
MKM_HTTP_TIMEOUT_SECONDS=3600
MKM_DAILY_LIMIT=0
# Optional: set a fixed key; if empty, container generates one on first boot
APP_KEY=
