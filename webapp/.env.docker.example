# Copy to webapp/.env.docker and adjust values for your machine

# Laravel container runtime variables
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
DB_CONNECTION=sqlite
MKM_API_URL=http://python-api:8080
# Must exceed worst-case LLM + RAG time or the client will close first (misleading "cannot reach API")
MKM_HTTP_TIMEOUT_SECONDS=3600
MKM_DAILY_LIMIT=0
# Optional: set a fixed key; if empty, container generates one on first boot
APP_KEY=
